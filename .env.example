# Klarim — example environment (NO real secrets here).
# Copy to .env and fill in real values for local/production use.

# --- PostgreSQL ---
POSTGRES_USER=klarim
POSTGRES_PASSWORD=change-me
POSTGRES_DB=klarim
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full SQLAlchemy/psycopg2 URL derived from the above:
DATABASE_URL=postgresql://klarim:change-me@db:5432/klarim

# --- Redis (scan queue + report cache) ---
REDIS_URL=redis://redis:6379/0
KLARIM_SCAN_QUEUE=klarim:scan_queue
KLARIM_REPORT_PREFIX=klarim:report:

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins for the dashboard.
CORS_ORIGINS=http://localhost:3000

# --- Web / HTTPS ---
# Domínio do site. VAZIO => o Nginx serve HTTP. Definido + certificado emitido
# (via deploy/setup-https.sh) => o Nginx serve HTTPS. É preenchido
# automaticamente pelo setup-https.sh na VM.
DOMAIN=

# --- Scanner tuning ---
# Per-request timeout (seconds) and per-domain rate limit (requests/second).
SCAN_TIMEOUT=10
SCAN_RATE_LIMIT=1

# --- Discovery Worker (KL-11 + KL-15) ---
# Fonte primária: poller de CT logs (lê os CT logs públicos direto, em tempo real
# — o Certstream público da calidog está morto). O crt.sh (KL-11) fica como
# fallback. O worker acumula domínios .com.br num buffer e o drena a cada
# DISCOVERY_INTERVAL_MINUTES.
DISCOVERY_BATCH_SIZE=100          # domínios processados por ciclo
DISCOVERY_INTERVAL_MINUTES=30     # intervalo entre ciclos (substitui _HOURS do KL-11)
# Blindagem contra travamento (KL-19): timeout TOTAL por domínio + watchdog que
# reinicia o processo se o event loop não progredir (o incidente de 08/07).
DISCOVERY_DOMAIN_TIMEOUT=30       # s por domínio (fetch+e-mail+registro)
DISCOVERY_WATCHDOG_SECONDS=600    # sem progresso por > isto → reinicia o processo
CT_LOG_LIST_URL=https://www.gstatic.com/ct/log_list/v3/log_list.json
CT_MAX_LOGS=5                     # quantos CT logs 'usable' amostrar em paralelo
CT_POLL_BATCH=256                # entradas amostradas do topo de cada log por poll
CT_POLL_INTERVAL_SECONDS=20      # intervalo entre polls do topo dos logs
WORKER_MAX_SCANS_PER_HOUR=50      # rate limit do scan worker

# --- Alert Worker (KL-12) ---
# Dispara o alerta gratuito para alvos escaneados com falhas. Throttle protege a
# reputação do domínio (Resend). Roda no mesmo container do Discovery Worker.
# Estratégia: lotes pequenos e frequentes (parece tráfego orgânico) — 4 e-mails a
# cada 30min, espaçados de 5s; em ~12h úteis chega a 90/dia (10 reservados p/
# transacionais; limite do Resend = 100/dia).
ALERT_INTERVAL_MINUTES=30        # intervalo entre ciclos (min); precede ALERT_INTERVAL_HOURS
MAX_ALERTS_PER_CYCLE=4           # máximo de alertas por ciclo
MAX_ALERTS_PER_HOUR=8            # teto por hora (2 ciclos × 4)
MAX_ALERTS_PER_DAY=90            # teto diário (reservar 10 p/ transacionais; Resend=100)
# Segredo do token de descadastro (HMAC). NUNCA commitar o valor real —
# gerar na VM com: openssl rand -hex 32
UNSUBSCRIBE_SECRET=

# --- Re-scan Worker (KL-13) ---
# Reescaneia alvos já engajados a cada 30 dias e envia e-mail de evolução do score.
# Roda no mesmo container do Discovery/Alert Worker. E-mails de evolução dividem o
# mesmo throttle (MAX_ALERTS_PER_HOUR/DAY) dos alertas.
RESCAN_INTERVAL_HOURS=24          # intervalo entre ciclos de re-scan
RESCAN_AGE_DAYS=30               # idade mínima do último scan para reescanear

# --- Dashboard admin (KL-14) ---
# Login único do operador em klarim.net/painel. NUNCA commitar os valores reais —
# ficam só no .env da VM. Gerar a senha e o secret na VM: openssl rand -hex 32
ADMIN_USER=admin
ADMIN_PASSWORD=          # senha do operador (openssl rand -hex 32)
JWT_SECRET=             # segredo de assinatura do JWT (openssl rand -hex 32)

# --- Notifier (email) — placeholder for Fase 2 ---
# One of: ses | resend | smtp
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=alerta@klarim.io

# --- Pagamento (AbacatePay PIX) — KL-7 ---
# NUNCA commitar a chave real. O .env da VM recebe os valores manualmente.
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
# KLARIM_DEV_MODE=true libera os PDFs sem pagamento (dev/testes). Além disso, se
# ABACATEPAY_API_KEY estiver vazia, o acesso também é livre (não há como vender).
KLARIM_DEV_MODE=false

# --- E-mail (Resend) — KL-8 ---
# NUNCA commitar a chave real. Configurada apenas no .env da VM.
RESEND_API_KEY=
# Remetente. Antes de verificar o domínio no Resend, use onboarding@resend.dev
# (funciona sem verificação). Depois: Klarim <seguranca@klarim.net>.
RESEND_FROM=Klarim <onboarding@resend.dev>
