---
export const prerender = false; // SSR: lê ?redirect= para voltar à rota protegida

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LoginForm from '../components/account/LoginForm.jsx';
import ClaimContext from '../components/account/ClaimContext.astro';

const params = Astro.url.searchParams;
const url = params.get('url') || '';
const email = params.get('email') || '';
// KL-68: se veio reivindicando um site, volta ao próprio perfil após entrar (senão dashboard).
const redirect = params.get('redirect') || '/dashboard';
---

<Base title="Entrar" description="Acesse sua conta Klarim." path="/entrar">
  <Header />
  <main class="mx-auto max-w-md px-5 pt-28 pb-20 sm:pt-32">
    <ClaimContext url={url} />
    <LoginForm client:load redirect={redirect} url={url} email={email} />
  </main>
  <Footer />
</Base>
