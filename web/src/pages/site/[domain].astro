---
export const prerender = false; // SSR: busca dados por domínio + SEO por página

import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ClaimSite from '../../components/account/ClaimSite.jsx';
import PrivacyPanel from '../../components/PrivacyPanel.jsx';

const SITE = 'https://klarim.net';
const API = process.env.KLARIM_API_URL || 'http://api:8000';
const domain = (Astro.params.domain || '').toLowerCase();

let data = null;
try {
  const res = await fetch(`${API}/public/profile/${encodeURIComponent(domain)}`, {
    signal: AbortSignal.timeout(6000),
  });
  if (res.ok) data = await res.json();
} catch { /* API indisponível → trata como não analisado */ }

const status = data?.status || 'not_found';

// Notifica o dono (best-effort) que o perfil foi consultado. /notify responde na hora
// (envio em background no backend) — await rápido com timeout curto.
// KL-44: encaminha o utm_campaign para o backend ignorar visitas do próprio dono vindas
// do e-mail de alerta (utm_campaign=alerta*) e evitar loop de notificação.
const utmCampaign = Astro.url.searchParams.get('utm_campaign') || '';
if (status === 'ok') {
  try {
    await fetch(`${API}/notify/profile-view`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ domain, utm_campaign: utmCampaign }),
      signal: AbortSignal.timeout(2500),
    });
  } catch { /* nunca bloqueia o perfil */ }
}

const SEMA = {
  verde: { dot: '🟢', label: 'Verde', ring: 'ring-green-500/50', text: 'text-green-400' },
  amarelo: { dot: '🟡', label: 'Amarelo', ring: 'ring-yellow-500/50', text: 'text-yellow-400' },
  vermelho: { dot: '🔴', label: 'Vermelho', ring: 'ring-red-500/50', text: 'text-red-400' },
};
const t = data?.target || {};
const p = data?.profile || {};
const cls = data?.classifications || [];
const bench = data?.benchmark || null;
const privacy = data?.privacy || null;  // KL-44 P5: indicadores técnicos (público = só score/total)
const sema = SEMA[t.semaphore] || SEMA.amarelo;
const scoreN = t.score ?? null;
const lastScan = t.last_scan_at ? new Date(t.last_scan_at).toLocaleDateString('pt-BR') : '—';
const pct = bench && bench.count > 0 && scoreN != null && bench.avg_score
  ? Math.min(99, Math.max(1, Math.round((scoreN / (bench.avg_score * 2 || 100)) * 100)))
  : null;

// SEO
const okTitle = `${domain} — Score de segurança: ${scoreN}/100 | Klarim`;
const okDesc = ((p.description ? p.description + ' ' : '')
  + `Score de segurança do site: ${scoreN}/100. Análise com 48 verificações.`).slice(0, 300);
const ogImage = status === 'ok' ? `${SITE}/api/og/${encodeURIComponent(domain)}.png` : undefined;
// Fix Schema.org (2026-07-17): o Review/`itemReviewed: WebSite` era INVÁLIDO (Google
// Search Console reprova WebSite como itemReviewed). Removido — o Organization + WebSite
// (site-wide, no Base) seguem válidos, e o score já é capturado pelo <title>/description/OG.
const jsonLd = undefined;

const card = 'rounded-2xl border border-slate-800 bg-slate-900/60 p-6';

// KL-66 — seção de contato com destaque. Só campos PÚBLICOS que o próprio site publica
// (o backend já filtra: whatsapp/cnpj/contact_email NUNCA vêm no perfil público, §39).
// Ícones SVG inline (strings estáticas → set:html seguro; label/href do perfil são
// escapados pela interpolação do Astro).
const svg = (inner) =>
  `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${inner}</svg>`;
const IC = {
  phone: svg('<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>'),
  map: svg('<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>'),
  globe: svg('<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>'),
  instagram: svg('<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>'),
  facebook: svg('<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>'),
  linkedin: svg('<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>'),
  youtube: svg('<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>'),
  tiktok: svg('<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>'),
};
const isSafeUrl = (u) => typeof u === 'string' && /^https?:\/\//i.test(u);
const phoneDigits = p.phone ? String(p.phone).replace(/[^\d+]/g, '') : '';
// Guard anti-lixo: alguns endereços vieram com classes CSS raspadas por engano — só
// exibe se parecer endereço (tem dígito ou vírgula). O fix do profiler é card futuro.
const addressOk = p.address && (/\d/.test(p.address) || p.address.includes(','));
const ytLabel = (h) => '@' + String(h).replace(/^(c|channel|user)\//, '').replace(/^@/, '');
const siteUrl = isSafeUrl(t.url) ? t.url : `https://${domain}`;
const monogram = ((p.company_name || domain).trim().charAt(0) || '?').toUpperCase();

// KL-68 — reivindicação de propriedade. `owner_verified`/`claimable`/`block_message`
// vêm do backend (nunca expõem quem é o dono nem o contact_email).
const ownerVerified = data?.owner_verified === true;
const claimable = data?.claimable !== false;
const blockMessage = data?.block_message || '';
const claimUrl = siteUrl;

const hasContact = !!(phoneDigits.length >= 8 || addressOk || p.instagram || p.facebook
  || p.linkedin || p.youtube || p.tiktok);
const contacts = [];
if (hasContact) {
  if (phoneDigits.length >= 8) contacts.push({ icon: IC.phone, label: p.phone, href: `tel:${phoneDigits}` });
  if (addressOk) contacts.push({ icon: IC.map, label: p.address, href: isSafeUrl(p.google_maps_url) ? p.google_maps_url : null, ext: true });
  if (p.instagram) contacts.push({ icon: IC.instagram, label: `@${p.instagram}`, href: `https://instagram.com/${p.instagram}`, ext: true });
  if (p.facebook) contacts.push({ icon: IC.facebook, label: p.facebook, href: `https://facebook.com/${p.facebook}`, ext: true });
  if (p.linkedin) contacts.push({ icon: IC.linkedin, label: p.linkedin, href: `https://linkedin.com/company/${p.linkedin}`, ext: true });
  if (p.youtube) contacts.push({ icon: IC.youtube, label: ytLabel(p.youtube), href: `https://youtube.com/${p.youtube}`, ext: true });
  if (p.tiktok) contacts.push({ icon: IC.tiktok, label: `@${p.tiktok}`, href: `https://tiktok.com/@${p.tiktok}`, ext: true });
  contacts.push({ icon: IC.globe, label: domain, href: siteUrl, ext: true });
}
---

<Base
  title={status === 'ok' ? domain : `Segurança de ${domain}`}
  fullTitleOverride={status === 'ok' ? okTitle : undefined}
  description={status === 'ok' ? okDesc : `Análise de segurança do site ${domain}.`}
  path={`/site/${domain}`}
  ogType="website"
  ogImage={ogImage}
  twitterCard={status === 'ok' ? 'summary_large_image' : 'summary'}
  jsonLd={jsonLd}
  noindex={status !== 'ok'}
>
  <Header />
  <main class="mx-auto max-w-2xl px-5 pt-28 pb-20 sm:pt-32">
    {status === 'discarded' && (
      <div class={card}>
        <h1 class="text-2xl font-bold text-white">{domain}</h1>
        <p class="mt-3 text-slate-300">Este site não está disponível para análise.</p>
        <a href="/" class="mt-6 inline-block text-brand-400 hover:text-brand-300">← Voltar ao início</a>
      </div>
    )}

    {(status === 'not_found' || status === 'not_scanned') && (
      <div class={card}>
        <h1 class="text-2xl font-bold text-white">{domain}</h1>
        <p class="mt-3 text-slate-300">Este site ainda não foi analisado pelo Klarim.</p>
        <a href={`/scan?url=${encodeURIComponent(domain)}`}
          class="mt-6 inline-flex rounded-xl bg-brand-500 px-6 py-3.5 text-base font-semibold text-slate-950 hover:bg-brand-400">
          Verificar agora →
        </a>
      </div>
    )}

    {status === 'ok' && (
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-brand-500/15 text-2xl font-bold text-brand-400 ring-1 ring-brand-500/30">{monogram}</div>
          <div class="min-w-0">
            <h1 class="truncate text-2xl font-bold tracking-tight text-white sm:text-3xl">{domain}</h1>
            <p class="mt-1 truncate text-sm text-slate-500">{p.company_name || 'Análise passiva de segurança do site'}</p>
          </div>
        </div>

        <div class={`${card} flex items-center gap-6`}>
          <div class={`flex h-32 w-32 shrink-0 flex-col items-center justify-center rounded-full ring-4 ${sema.ring}`}>
            <span class={`text-5xl font-extrabold ${sema.text}`}>{scoreN}</span>
            <span class="text-xs text-slate-500">/100</span>
          </div>
          <div>
            <p class="text-2xl">{sema.dot} <span class="align-middle text-lg text-slate-300">{sema.label}</span></p>
            <p class="mt-2 text-sm text-slate-400">Score de segurança do site</p>
            <p class="text-sm text-slate-500">Última análise: {lastScan}</p>
            {ownerVerified && (
              <p class="mt-2 inline-flex items-center gap-1 rounded-full border border-green-500/40 bg-green-500/10 px-2.5 py-0.5 text-xs font-semibold text-green-400">
                ✓ Dono verificado
              </p>
            )}
          </div>
        </div>

        {/* KL-68 — reivindicação acima do fold (logo após o score), condicional ao login. */}
        <ClaimSite client:load url={claimUrl} domain={domain}
          ownerVerified={ownerVerified} claimable={claimable} blockMessage={blockMessage} />

        {hasContact && (
          <div class={card}>
            <h2 class="text-lg font-bold text-white">Contato</h2>
            <p class="mt-1 text-sm text-slate-400">Dados que o Klarim encontrou publicados no site.</p>
            <ul class="mt-4 grid gap-3 sm:grid-cols-2">
              {contacts.map((c) => (
                <li class="flex items-center gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-slate-800 text-brand-400" set:html={c.icon} />
                  {c.href
                    ? <a href={c.href} target={c.ext ? '_blank' : undefined} rel={c.ext ? 'noopener noreferrer' : undefined} class="truncate text-slate-200 hover:text-brand-300">{c.label}</a>
                    : <span class="truncate text-slate-200">{c.label}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        {(p.description || p.business_type || cls.length > 0 || (p.tags && p.tags.length > 0) || p.maturity_score != null || t.platform) && (
          <div class={card}>
            <h2 class="text-lg font-bold text-white">Sobre este site</h2>
            {p.description && <p class="mt-2 text-slate-300">{p.description}</p>}
            <dl class="mt-4 space-y-1.5 text-sm">
              {p.business_type && <div class="flex gap-2"><dt class="w-32 shrink-0 text-slate-500">Tipo</dt><dd class="text-slate-200">{p.business_type}</dd></div>}
              {cls.length > 0 && (
                <div class="flex gap-2"><dt class="w-32 shrink-0 text-slate-500">CNAE</dt>
                  <dd class="text-slate-200">{cls.slice(0, 3).map((c) => `${c.cnae_code} ${c.cnae_description || ''}`.trim()).join(' · ')}</dd></div>
              )}
              {Array.isArray(p.tags) && p.tags.length > 0 && <div class="flex gap-2"><dt class="w-32 shrink-0 text-slate-500">Tags</dt><dd class="text-slate-200">{p.tags.join(', ')}</dd></div>}
              {p.maturity_score != null && <div class="flex gap-2"><dt class="w-32 shrink-0 text-slate-500">Maturidade digital</dt><dd class="text-slate-200">{p.maturity_score}/10</dd></div>}
              {t.platform && <div class="flex gap-2"><dt class="w-32 shrink-0 text-slate-500">Plataforma</dt><dd class="text-slate-200">{t.platform}</dd></div>}
            </dl>
          </div>
        )}

        {/* KL-44 P5 — Indicadores técnicos de privacidade (score SEPARADO do de segurança).
            Fix compliance: o perfil PÚBLICO só recebe score/total da API. A ilha revela os
            detalhes (✅/❌ + ref LGPD) apenas a visitantes LOGADOS, via endpoint autenticado.
            Nada de detalhe vai para o HTML do SSR (nem no view-source deslogado). */}
        {privacy && privacy.score != null && (
          <PrivacyPanel client:load domain={domain} score={privacy.score} total={privacy.total} />
        )}

        {bench && bench.count > 0 && (
          <div class={card}>
            <p class="text-sm font-medium uppercase tracking-wide text-brand-400/80">Benchmark{bench.sector_label ? ` — ${bench.sector_label}` : ''}</p>
            <p class="mt-2 text-slate-300">Score deste site: <span class="font-bold text-white">{scoreN}</span> · Média{bench.scope === 'sector' ? ' do setor' : ' nacional'}: <span class="font-bold text-white">{bench.avg_score}</span>{bench.median != null ? <span class="text-slate-500"> · mediana {bench.median}</span> : null}</p>
            <p class="mt-1 text-sm text-slate-400">{scoreN >= bench.avg_score ? 'Acima da média ↑' : 'Abaixo da média ↓ — há espaço para melhorar.'}</p>
            {bench.distribution && (
              <div class="mt-4 space-y-1 text-sm">
                <p class="text-xs uppercase tracking-wide text-slate-500">Distribuição do setor ({bench.count} sites)</p>
                <p class="text-slate-300">🟢 Excelente (≥90): <span class="font-semibold text-white">{bench.distribution.green_pct}%</span></p>
                <p class="text-slate-300">🟡 Adequado (50–89): <span class="font-semibold text-white">{bench.distribution.yellow_pct}%</span></p>
                <p class="text-slate-300">🔴 Crítico (&lt;50): <span class="font-semibold text-white">{bench.distribution.red_pct}%</span></p>
              </div>
            )}
          </div>
        )}

        <div class="text-center">
          <a href="/scan" data-cta="verify-other" class="text-sm text-brand-400 hover:text-brand-300">🔍 Verificar outro site →</a>
        </div>

        <p class="border-t border-slate-800 pt-6 text-xs leading-relaxed text-slate-600">
          Este score é baseado em análise passiva automatizada do site e não constitui auditoria de
          segurança. O Klarim avalia a segurança do <strong>site</strong>, não do negócio.
        </p>
      </div>
    )}
  </main>
  <Footer />
</Base>
