---
export const prerender = false;

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ForgotForm from '../components/account/ForgotForm.jsx';
import { FORM_CONTAINER } from '../lib/layout.js';

const params = Astro.url.searchParams;   // KL-68: preserva o contexto de claim
const url = params.get('url') || '';
const email = params.get('email') || '';
---

<Base title="Recuperar senha" description="Redefina a senha da sua conta Klarim." path="/recuperar-senha">
  <Header />
  <main class={FORM_CONTAINER}>
    <ForgotForm client:load url={url} email={email} />
  </main>
  <Footer />
</Base>
