---
export const prerender = true;

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';

// KL-81 fix — footer MÍNIMO só na landing (sem logo/tagline/min-h pesado) — o Footer
// compartilhado (com logo + "Segurança web para o Brasil.") segue nas demais páginas.
const footerLinks = [
  { href: '/setores', label: 'Setores' },
  { href: '/melhores', label: 'Melhores' },
  { href: '/estatisticas', label: 'Estatísticas' },
  { href: '/termos', label: 'Termos de Uso' },
  { href: '/privacidade', label: 'Política de Privacidade' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
];

// KL-81 — landing minimalista tipo buscador: "Pesquise qualquer site". Hero + footer
// apenas (removidas as seções Como funciona / checks / benchmark / Para quem). A busca
// (GET /scan?url=) é idêntica — só mudou o texto/botão.
const description =
  'Pesquise a segurança de qualquer site brasileiro em 30 segundos. ' +
  'Relatório completo e 100% gratuito, sem cadastro.';

// KL-65 — SoftwareApplication reforça que o Klarim é uma ferramenta de segurança.
const softwareApplication = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Klarim Scanner',
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
  description: 'Scanner passivo de segurança web. Avalia SSL, headers, DNS, LGPD, OWASP Top 10 e mais 48 verificações sem invadir o site.',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '1',
    bestRating: '5',
  },
};
---

<Base title="Klarim" description={description} path="/" jsonLd={softwareApplication}>
  {/* KL-81: nav no topo (header é `absolute`), hero centralizado (main flex-1), footer no fundo.
      Cabe numa tela sem scroll. */}
  {/* KL-81: 100dvh (compensa a barra de URL do Safari iOS); hero centralizado (main flex-1);
      footer mínimo no fundo. Cabe numa tela sem scroll. */}
  <div class="flex min-h-[100dvh] flex-col">
    <Header />

    <main class="flex flex-1 items-center justify-center px-5 py-8">
      <div class="w-full max-w-2xl text-center">
        {/* Fonte menor (fix polish): cabe em 1 linha no desktop; ~2 linhas no mobile é ok. */}
        <h1 class="text-balance text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
          Pesquise qualquer site.
        </h1>
        <p class="mt-3 text-xl font-semibold text-brand-400 sm:text-2xl">
          Descubra em 30 segundos.
        </p>

        {/* Busca — GET /scan?url=… (funciona sem JS). Botão EMBUTIDO no campo (estilo buscador):
            container com borda + focus-within; input transparente; botão inline (não empilha,
            nem no mobile). */}
        <form action="/scan" method="get" class="mt-8 w-full">
          <div class="flex items-center rounded-2xl border border-slate-700 bg-slate-900 transition-all focus-within:border-brand-500 focus-within:ring-2 focus-within:ring-brand-500/30">
            <span class="pl-4 text-slate-500 sm:pl-5" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M21 21l-4.3-4.3"></path>
              </svg>
            </span>
            <label for="hero-url" class="sr-only">Domínio do site</label>
            <input
              id="hero-url"
              name="url"
              type="text"
              inputmode="url"
              autocapitalize="none"
              autocorrect="off"
              autocomplete="off"
              spellcheck="false"
              required
              placeholder="digite um domínio..."
              class="h-14 min-w-0 flex-1 border-none bg-transparent px-3 text-base text-white placeholder:text-slate-500 focus:outline-none"
            />
            <button
              type="submit"
              class="m-1.5 inline-flex h-11 shrink-0 items-center justify-center whitespace-nowrap rounded-xl bg-brand-500 px-4 text-base font-semibold text-slate-950 transition-all hover:bg-brand-400 active:scale-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-300 sm:px-8"
            >
              Pesquisar →
            </button>
          </div>
        </form>

        <p class="mt-4 text-sm text-slate-500">Relatório completo. 100% gratuito.</p>
      </div>
    </main>

    {/* KL-81 fix — footer mínimo (só links + copyright), leve, para o hero centralizar. */}
    <footer class="border-t border-slate-800 bg-slate-950 px-5 py-6">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 text-center">
        <nav class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm">
          {footerLinks.map((l) => (
            <a href={l.href} class="text-slate-400 transition-colors hover:text-white">{l.label}</a>
          ))}
        </nav>
        <p class="max-w-md text-xs leading-relaxed text-slate-600">
          © 2026 Klarim. Scanner 100% passivo — analisa apenas o que o site já entrega
          publicamente. Nenhum dado privado é coletado.
        </p>
      </div>
    </footer>
  </div>
</Base>
