---
export const prerender = false; // SSR: valida o token no backend e redireciona

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// KL-82 Slice 2 — confirmação de e-mail por LINK. Lê ?token=, chama o backend server-side
// e, no sucesso, redireciona para o dashboard com o toast. O token nunca vai ao cliente.
const token = Astro.url.searchParams.get('token') || '';
const API = process.env.KLARIM_API_URL || 'http://api:8000';

let status = 'invalid';
if (token) {
  try {
    const res = await fetch(`${API}/account/confirm?token=${encodeURIComponent(token)}`, {
      signal: AbortSignal.timeout(5000),
    });
    if (res.ok) status = (await res.json()).status || 'invalid';
  } catch { status = 'error'; }
}

// Sucesso (confirmou agora ou já estava confirmado) → dashboard com toast.
if (status === 'confirmed') return Astro.redirect('/dashboard?confirmed=1');
if (status === 'already') return Astro.redirect('/dashboard?confirmed=already');
---

<Base title="Confirmação de e-mail" description="Confirmação de e-mail — Klarim." path="/confirmar">
  <Header />
  <main class="mx-auto flex min-h-[60vh] max-w-md flex-col items-center justify-center px-5 pt-28 pb-20 text-center sm:pt-32">
    <div class="w-full rounded-2xl border border-slate-800 bg-slate-900/60 p-6 sm:p-8">
      <p class="text-3xl" aria-hidden="true">⚠️</p>
      <h1 class="mt-3 text-xl font-bold text-white">Link de confirmação inválido ou expirado</h1>
      <p class="mt-2 text-sm text-slate-400">
        O link pode ter expirado (vale 30 dias) ou já foi usado. Entre na sua conta e reenvie
        um novo link de confirmação pelo painel.
      </p>
      <a href="/entrar"
        class="mt-5 inline-flex min-h-[44px] w-full items-center justify-center rounded-xl bg-brand-500 px-6 py-3 text-base font-semibold text-slate-950 transition-colors hover:bg-brand-400 sm:w-auto">
        Entrar na conta →
      </a>
    </div>
  </main>
  <Footer />
</Base>
