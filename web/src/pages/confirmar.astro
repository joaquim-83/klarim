---
export const prerender = false; // SSR: só redireciona — NÃO chama a API (anti pre-fetch).

// Rota LEGADA (e-mails antigos linkavam /confirmar?token=). 2026-07-21: não confirma mais no
// load (o pre-fetch do e-mail confirmaria a conta sem o usuário). Apenas repassa o token para a
// página /confirmado, que mostra o botão (a confirmação só ocorre no POST do clique humano).
const token = Astro.url.searchParams.get('token') || '';
return Astro.redirect(token ? `/confirmado?token=${encodeURIComponent(token)}` : '/confirmado?status=invalid');
---
