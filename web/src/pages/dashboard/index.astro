---
export const prerender = false; // SSR + protegido pelo middleware (JWT no cookie)

import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Dashboard from '../../components/account/Dashboard.jsx';

// O middleware (src/middleware.js) já validou o JWT e injetou o usuário; se chegou
// aqui, está autenticado.
const user = Astro.locals.user || {};
---

<Base title="Dashboard" description="Seus sites monitorados no Klarim." path="/dashboard" noindex={true}>
  <Header />
  <main class="mx-auto max-w-3xl px-5 pt-28 pb-20 sm:pt-32">
    <Dashboard client:load user={user} />
  </main>
  <Footer />
</Base>
