---
export const prerender = false; // SSR: lê email/url/redirect da query (vindos do scan)

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupForm from '../components/account/SignupForm.jsx';
import ClaimContext from '../components/account/ClaimContext.astro';
import { FORM_CONTAINER } from '../lib/layout.js';

const params = Astro.url.searchParams;
const email = params.get('email') || '';
const url = params.get('url') || '';
const redirect = params.get('redirect') || '/dashboard';
const role = params.get('role') === 'technician' ? 'technician' : '';   // KL-44 P3
const invite = params.get('invite') || '';
const plan = ['pro', 'agency'].includes(params.get('plan')) ? params.get('plan') : '';   // KL-44 P6
---

<Base
  title="Criar conta"
  description="Crie sua conta gratuita no Klarim e monitore a segurança do seu site com re-scan mensal e alertas."
  path="/cadastrar"
>
  <Header />
  <main class={FORM_CONTAINER}>
    <ClaimContext url={url} />
    <SignupForm client:load email={email} url={url} redirect={redirect} role={role} invite={invite} plan={plan} />
  </main>
  <Footer />
</Base>
