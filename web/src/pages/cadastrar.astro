---
export const prerender = false; // SSR: lê email/url/redirect da query (vindos do scan)

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupForm from '../components/account/SignupForm.jsx';
import ClaimContext from '../components/account/ClaimContext.astro';

const params = Astro.url.searchParams;
const email = params.get('email') || '';
const url = params.get('url') || '';
const redirect = params.get('redirect') || '/dashboard';
---

<Base
  title="Criar conta"
  description="Crie sua conta gratuita no Klarim e monitore a segurança do seu site com re-scan mensal e alertas."
  path="/cadastrar"
>
  <Header />
  <main class="mx-auto max-w-md px-5 pt-28 pb-20 sm:pt-32">
    <ClaimContext url={url} />
    <SignupForm client:load email={email} url={url} redirect={redirect} />
  </main>
  <Footer />
</Base>
