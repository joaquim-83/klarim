---
export const prerender = false; // SSR: lê ?url= e passa ao island

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScanFlow from '../components/scan/ScanFlow.jsx';

const url = Astro.url.searchParams.get('url') || '';

// Auth (KL-51 f3 fix UX): usuário logado escaneia sem código de e-mail. Lê o cookie
// e valida no backend; passa o user (ou null) ao island.
const API = process.env.KLARIM_API_URL || 'http://api:8000';
let user = null;
const sessionToken = Astro.cookies.get('klarim_session')?.value;
if (sessionToken) {
  try {
    // Timeout curto: se a API estiver ocupada (scan em andamento), não travar o render
    // da página — cai para deslogado (o fluxo com e-mail/código ainda funciona).
    const res = await fetch(`${API}/account/me`, {
      headers: { Authorization: `Bearer ${sessionToken}` },
      signal: AbortSignal.timeout(4000),
    });
    if (res.ok) user = (await res.json()).user;
  } catch { /* deslogado ou timeout */ }
}

function safeDomain(u) {
  if (!u) return '';
  try {
    return new URL(u.includes('://') ? u : `https://${u}`).hostname.replace(/^www\./, '');
  } catch {
    return u;
  }
}
const domain = safeDomain(url);
---

<Base
  title={domain ? `Analisando ${domain}` : 'Análise de segurança'}
  description="Análise de segurança do seu site — 48 verificações, score e relatório completo, gratuito."
  path="/scan"
>
  <Header />
  <main class="mx-auto max-w-3xl px-5 pt-28 pb-20 sm:pt-32">
    <ScanFlow url={url} user={user} client:load />
    <noscript>
      <p class="mt-6 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">
        A análise interativa precisa de JavaScript. Ative-o para escanear seu site.
      </p>
    </noscript>
  </main>
  <Footer />
</Base>
