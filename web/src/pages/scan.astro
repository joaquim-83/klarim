---
export const prerender = false; // SSR: lê ?url= e passa ao island

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScanFlow from '../components/scan/ScanFlow.jsx';
import { PAGE_CONTAINER } from '../lib/layout.js';
import { scanTitle } from '../lib/scanTitle.js';

const url = Astro.url.searchParams.get('url') || '';

// KL-82 (confiança progressiva): a ilha escaneia via /api/scan/result e o backend decide o
// nível de acesso a partir do cookie de sessão (enviado com credentials:'include'). Não é
// mais preciso resolver o usuário no SSR — reduz a latência do render.

// Fix de segurança (2026-07-21): o `?url=` NUNCA é refletido cru no <title> — só o hostname
// sanitizado (ou "um site" se não parsear). Lógica pura e testada em lib/scanTitle.js.
const pageTitle = scanTitle(url);
---

<Base
  title={pageTitle}
  description="Pesquise a segurança de qualquer site — 48 verificações, score e relatório, gratuito e sem cadastro."
  path="/scan"
>
  <Header />
  <main class={PAGE_CONTAINER}>
    <ScanFlow url={url} client:load />
    <noscript>
      <p class="mt-6 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-3 text-sm text-amber-300">
        A análise interativa precisa de JavaScript. Ative-o para pesquisar um site.
      </p>
    </noscript>
  </main>
  <Footer />
</Base>
