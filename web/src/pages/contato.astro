---
export const prerender = false; // página pública; o form é uma ilha React (POST client-side)

import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.jsx';
import { FORM_CONTAINER } from '../lib/layout.js';

// O formulário é uma ilha React que faz POST para /api/contact (FastAPI) via fetch —
// evita a proteção CSRF do Astro SSR (`checkOrigin`), que barrava o POST do form nativo
// atrás do Cloudflare ("Cross-site POST form submissions are forbidden"), KL-58.
---

<Base
  title="Fale conosco"
  description="Fale com o time do Klarim. Envie sua mensagem e respondemos em até 48h, ou escreva para scan@klarim.net."
  path="/contato"
>
  <Header />
  <main class={FORM_CONTAINER}>
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Fale conosco</h1>
    <ContactForm client:load />
  </main>
  <Footer />
</Base>
