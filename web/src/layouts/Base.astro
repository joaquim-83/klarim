---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  /** Caminho da rota (para canonical/og:url). Ex.: "/termos". */
  path?: string;
  /** Rotas privadas (dashboard) não devem ser indexadas. */
  noindex?: boolean;
  /** URL absoluta do og:image (default: favicon). */
  ogImage?: string;
  /** og:type (default 'website'). */
  ogType?: string;
  /** twitter:card (default 'summary'; 'summary_large_image' p/ perfis). */
  twitterCard?: string;
  /** Título completo exato (ignora o sufixo "· Klarim"). Ex.: perfis públicos. */
  fullTitleOverride?: string;
  /** JSON-LD (structured data) — objeto serializado num <script ld+json>. */
  jsonLd?: unknown;
}

const {
  title, description, path = '/', noindex = false,
  ogImage, ogType = 'website', twitterCard = 'summary_large_image',
  fullTitleOverride, jsonLd,
} = Astro.props;
const SITE = 'https://klarim.net';
const canonical = new URL(path, SITE).href;
const fullTitle = fullTitleOverride
  ? fullTitleOverride
  : title === 'Klarim' ? 'Klarim — Segurança web para o Brasil' : `${title} · Klarim`;
const ogImageUrl = ogImage || `${SITE}/og-image.png`;

// KL-65 — sinais de autoridade p/ o Google (JSON-LD sempre presente nas páginas
// públicas; o admin usa AdminLayout, sem isto). Organization + WebSite reforçam que
// Klarim é uma empresa legítima de segurança web (o AI Overview confundia com "Clarim").
const ORG_JSONLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Klarim',
  url: SITE,
  logo: `${SITE}/favicon.svg`,
  description: 'Plataforma brasileira de segurança web. Scanner passivo que avalia e monitora a postura de segurança de sites, sem invasão.',
  foundingDate: '2026',
  areaServed: 'BR',
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'contato@klarim.net',
    contactType: 'customer support',
    availableLanguage: 'Portuguese',
  },
  knowsAbout: ['Web Security', 'LGPD Compliance', 'SSL/TLS', 'OWASP Top 10',
    'Passive Security Scanning', 'Website Monitoring'],
};
const WEBSITE_JSONLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Klarim',
  url: SITE,
  description: 'Verifique a segurança do seu site em segundos. Scanner passivo e gratuito para empresas brasileiras.',
  inLanguage: 'pt-BR',
  publisher: { '@type': 'Organization', name: 'Klarim' },
};
// Org + WebSite sempre; o `jsonLd` da página (objeto ou array) entra depois.
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [ORG_JSONLD, WEBSITE_JSONLD, ...extraLd];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Klarim" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#020617" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Klarim" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {allJsonLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
    ))}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased selection:bg-brand-500/30">
    <slot />
    <!-- Tracking (KL-21): asset EXTERNO (não inline) → passa na CSP `script-src 'self'`. -->
    <script src="/track.js" is:inline></script>
  </body>
</html>
