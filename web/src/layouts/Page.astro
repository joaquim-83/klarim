---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  path?: string;
  updated?: string;
}

const { title, description, path, updated } = Astro.props;
---

<Base title={title} description={description} path={path}>
  <Header />
  <main class="mx-auto max-w-3xl px-5 pt-28 pb-20 sm:pt-32">
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{title}</h1>
    {updated && <p class="mt-3 text-sm text-slate-500">Última atualização: {updated}</p>}
    <div class="prose-klarim mt-8">
      <slot />
    </div>
    <p class="mt-12 border-t border-slate-800 pt-6 text-sm">
      <a href="/" class="text-emerald-400 hover:text-emerald-300">← Voltar ao início</a>
    </p>
  </main>
  <Footer />
</Base>
