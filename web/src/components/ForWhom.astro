---
const audiences = [
  {
    tag: 'Donos de negócio',
    text: 'Saiba se o site da sua empresa está protegido — em linguagem que você entende, sem jargão técnico.',
    soon: false,
  },
  {
    tag: 'Profissionais de TI',
    text: 'Relatório técnico com OWASP, CWE e LGPD. Detecção de componentes vulneráveis via CVE matching (Retire.js).',
    soon: false,
  },
  {
    tag: 'Agências',
    text: 'Monitore os sites dos seus clientes e entregue relatórios com a sua marca.',
    soon: true,
  },
];
---

<section class="px-5 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <h2 class="text-center text-2xl font-bold text-white sm:text-3xl">Para quem é o Klarim</h2>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {audiences.map((a) => (
        <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
          <div class="flex items-center gap-2">
            <h3 class="font-semibold text-white">{a.tag}</h3>
            {a.soon && (
              <span class="rounded-full border border-amber-500/40 bg-amber-500/10 px-2 py-0.5 text-[11px] font-medium text-amber-400">em breve</span>
            )}
          </div>
          <p class="mt-3 text-sm leading-relaxed text-slate-400">{a.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
