---
import Logo from './Logo.astro';
// Contas de usuário (KL-51 f3). O cookie de sessão é HttpOnly (JS não lê), então o
// header começa deslogado e um script consulta /api/account/me para alternar o nav.
---

<header class="absolute inset-x-0 top-0 z-10">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-5">
    <a href="/" aria-label="Página inicial do Klarim" class="rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
      <Logo />
    </a>

    <div class="flex items-center gap-1">
    <!-- KL-87: alternar tema claro/escuro (sol/lua). O ícone é sincronizado por /theme.js. -->
    <button id="theme-toggle" type="button" aria-label="Alternar tema claro/escuro"
      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg text-slate-300 transition-colors hover:bg-slate-800 hover:text-white">
      <span id="theme-icon-light" class="hidden text-lg" aria-hidden="true">🌙</span>
      <span id="theme-icon-dark" class="hidden text-lg" aria-hidden="true">☀️</span>
    </button>

    <!-- Estado deslogado (padrão) -->
    <div data-auth="out" class="flex items-center gap-1">
      <a href="/planos" class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:text-white">Planos</a>
      <a href="/entrar" class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:text-white">Entrar</a>
      <a href="/cadastrar" class="inline-flex min-h-[44px] items-center rounded-lg bg-brand-500 px-3.5 py-2 text-sm font-semibold text-[var(--accent-text)] transition-colors hover:bg-brand-400 active:scale-95">Cadastrar</a>
    </div>

    <!-- Estado logado (revelado pelo script). KL-78 item 7: "Planos" aponta para a página
         pública /planos (3 cards comparativos) — o usuário logado precisa ver as opções, não
         só o plano atual. O CTA de upgrade fica na PlanSection do dashboard. Nav curto no mobile. -->
    <div data-auth="in" class="hidden items-center gap-1">
      <a href="/planos" class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:text-white">Planos</a>
      <a href="/dashboard" class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:text-white">Home</a>
      <a href="/dashboard/conta" class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-300 transition-colors hover:text-white">Conta</a>
      <button type="button" data-logout class="inline-flex min-h-[44px] items-center rounded-lg px-3 py-2 text-sm font-medium text-slate-400 transition-colors hover:text-white">Sair</button>
    </div>
    </div>
  </nav>
</header>

<script>
  (async () => {
    const out = document.querySelector('[data-auth="out"]');
    const inn = document.querySelector('[data-auth="in"]');
    try {
      const res = await fetch('/api/account/me', { credentials: 'include' });
      if (res.ok) {
        out?.classList.add('hidden');
        inn?.classList.remove('hidden');
        inn?.classList.add('flex');
      }
    } catch { /* deslogado: mantém o padrão */ }
    document.querySelector('[data-logout]')?.addEventListener('click', async () => {
      try { await fetch('/api/account/logout', { method: 'POST', credentials: 'include' }); } catch {}
      window.location.href = '/';
    });
  })();
</script>
